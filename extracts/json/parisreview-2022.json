    {
      "text": "\n\n\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\n\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tDonate to The Paris Review\n\t\t\t\t\t\tBy The Paris Review\n\t\t\t\t\t\t\u00a0\n\t\t\t\t\t\t\n\t\t\t\t\t\t\tThe Paris Review promotes the most exciting writers of the day and supports inquisitive readers the world over.\n\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\n\t\t\t\t\t\t\t\t\tDonate\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\t\t",
      "url": "https://www.theparisreview.org/donate-to-the-paris-review"
    },
    {
      "text": "\n\n\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\n\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\tDiary, 2001\n\t\t\t\t\t\tBy Molly Dektar\n\t\t\t\t\t\tJuly 7, 2022\u00a0\n\t\t\t\t\t\t\n\t\t\t\t\t\t\t\u201cToday I\u2019m REALLY worried about death. I almost started crying. However, my new calligraphy kit is AWSOME.\u201d\n\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\n\n\t\t\t\t\t\t\t\t\t\t\tThe Daily\n\t\t\t\t\t\t\t\t\t\t\tDiaries\n\t\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\n\t\t\t\t\t\t",
