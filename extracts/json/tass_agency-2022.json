    },
    {
      "text": "\u0412 \u0418\u0437\u0440\u0430\u0438\u043b\u0435 \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0430\u043b\u0438 \u043c\u0435\u0442\u043e\u0434\u0438\u043a\u0443 \u0440\u0430\u043d\u043d\u0435\u0439 \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0438 \u0431\u043e\u043b\u0435\u0437\u043d\u0438 \u041f\u0430\u0440\u043a\u0438\u043d\u0441\u043e\u043d\u0430",
      "url": "/nauka/15231221"
