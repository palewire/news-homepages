    },
    {
      "text": "\u041d\u0430\u0443\u043a\u0430",
      "url": "/nauka"
    },
    {
      "text": "\u0423\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0438 \u043d\u0430\u0443\u0447\u043d\u043e\u0439 \u0448\u043a\u043e\u043b\u044b \u0432 \u0418\u043d\u0433\u0443\u0448\u0435\u0442\u0438\u0438 \u043e\u0431\u0441\u0443\u0434\u044f\u0442 \u043a\u043e\u0434\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0434\u0430\u043d\u043d\u044b\u0445 \u043d\u0435\u0439\u0440\u043e\u043d\u0430\u043c\u0438 \u043c\u043e\u0437\u0433\u0430\u041d\u0430 \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u0438 \u0441\u043e\u0431\u0435\u0440\u0443\u0442\u0441\u044f 40 \u043c\u043e\u043b\u043e\u0434\u044b\u0445 \u0443\u0447\u0435\u043d\u044b\u0445",
      "url": "/nauka/15239743"
    },
    {
      "text": "\u0412 \u0440\u0430\u0431\u043e\u0442\u0435 \u0438\u043d\u0442\u0435\u043d\u0441\u0438\u0432\u0430 \"\u0410\u0440\u0445\u0438\u043f\u0435\u043b\u0430\u0433\" \u0432 \u0421\u0435\u0432\u0430\u0441\u0442\u043e\u043f\u043e\u043b\u0435 \u043f\u0440\u0438\u043d\u044f\u043b\u0438 \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0443\u0436\u0435 \u0431\u043e\u043b\u0435\u0435 1,7 \u0442\u044b\u0441. \u0447\u0435\u043b\u043e\u0432\u0435\u043a",
      "url": "/nauka/15239131"
    },
    {
      "text": "\u042d\u043a\u0441\u043f\u0435\u0440\u0442: \u0420\u043e\u0441\u0441\u0438\u044f \u043d\u0443\u0436\u0434\u0430\u0435\u0442\u0441\u044f \u0432 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u0438 \u0435\u0434\u0438\u043d\u043e\u0439 \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u044b \u0434\u043b\u044f \u0418\u0418-\u0441\u0435\u0440\u0432\u0438\u0441\u043e\u0432",
      "url": "/nauka/15238733"
    },
    {
      "text": "\u0412 \u0420\u043e\u0441\u0441\u0438\u0438 \u0437\u0430\u043f\u0443\u0441\u0442\u044f\u0442 \u043a\u043e\u043d\u043a\u0443\u0440\u0441\u044b \u043f\u043e \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044e \u0431\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u044b\u0445 \u0433\u0440\u0443\u0437\u043e\u0432\u0438\u043a\u043e\u0432 \u0438 \u0441\u0438\u0441\u0442\u0435\u043c \u0434\u0438\u0430\u0433\u043d\u043e\u0441\u0442\u0438\u043a\u0438 \u0434\u0438\u0430\u0431\u0435\u0442\u0430",
      "url": "/nauka/15238497"
    },
    {
      "text": "\u042f\u043f\u043e\u043d\u0438\u044f \u0432 \u0430\u0432\u0433\u0443\u0441\u0442\u0435 \u043d\u0430\u0447\u043d\u0435\u0442 \u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0442\u044c \u0437\u0430\u044f\u0432\u043a\u0438 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u0439 \u043d\u0430 \u043e\u0431\u0440\u0430\u0437\u0446\u044b \u0441 \u0430\u0441\u0442\u0435\u0440\u043e\u0438\u0434\u0430 \u0420\u044e\u0433\u0443\u0418\u0445 \u0440\u0430\u0441\u0441\u043c\u043e\u0442\u0440\u0435\u043d\u0438\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u0441\u044f \u0432 \u044f\u043d\u0432\u0430\u0440\u0435 2023 \u0433\u043e\u0434\u0430",
      "url": "/nauka/15236647"
    },
    {
      "text": "\u0412 \u0420\u043e\u0441\u0441\u0438\u0438 \u0441\u0442\u0430\u0440\u0442\u043e\u0432\u0430\u043b \u043a\u043e\u043d\u043a\u0443\u0440\u0441 \u0441\u0440\u0435\u0434\u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0447\u0438\u043a\u043e\u0432 \u043d\u0430 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u0431\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u044b\u0445 \u0441\u0438\u0441\u0442\u0435\u043c \u0434\u043e\u0441\u0442\u0430\u0432\u043a\u0438\u0422\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u043a\u043e\u043d\u043a\u0443\u0440\u0441 \u041d\u0422\u0418 Up Great \"\u0410\u044d\u0440\u043e\u043b\u043e\u0433\u0438\u0441\u0442\u0438\u043a\u0430\" \u0431\u0443\u0434\u0435\u0442 \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u0442\u044c \u0432 2022-2024 \u0433\u043e\u0434\u0430\u0445",
      "url": "/nauka/15233469"
    },
    {
      "text": "\u0423\u0447\u0435\u043d\u044b\u0435 \u043d\u0430\u0448\u043b\u0438 \u0441\u043f\u043e\u0441\u043e\u0431 \u043f\u0435\u0440\u0435\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u0421\u041e2 \u0432 \u043c\u0435\u0442\u0430\u043d\u043e\u043b \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u043a\u043e\u043c\u043f\u043e\u043d\u0435\u043d\u0442\u044b \u0434\u043b\u044f \u043f\u0440\u043e\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u043e\u0441\u0442\u0438\u041d\u043e\u0432\u044b\u0439 \u043f\u043e\u0434\u0445\u043e\u0434 \u043f\u0440\u0435\u0434\u043f\u043e\u043b\u0430\u0433\u0430\u0435\u0442 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u043a\u0430\u0442\u0430\u043b\u0438\u0437\u0430\u0442\u043e\u0440\u043e\u0432, \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0445 \u043e\u043a\u0441\u0438\u0434 \u0438\u043d\u0434\u0438\u044f \u0438 \u0446\u0435\u043e\u043b\u0438\u0442\u043d\u044b\u0435 \u0441\u0438\u0441\u0442\u0435\u043c\u044b",
      "url": "/nauka/15232711"
    },
    {
      "text": "\u0420\u041d\u041a-\u0432\u0430\u043a\u0446\u0438\u043d\u044b \u043e\u0442 \u043a\u043e\u0440\u043e\u043d\u0430\u0432\u0438\u0440\u0443\u0441\u0430 \u0443\u0441\u0438\u043b\u0438\u0432\u0430\u044e\u0442 \u043c\u0435\u043d\u0441\u0442\u0440\u0443\u0430\u043b\u044c\u043d\u044b\u0435 \u043a\u0440\u043e\u0432\u043e\u0442\u0435\u0447\u0435\u043d\u0438\u044f",
