    },
    {
      "text": "",
      "url": "/"
    },
    {
      "text": "\u041a\u043b\u0438\u0448\u0430\u0441: \u0443\u0433\u0440\u043e\u0437\u044b \u0430\u0442\u0430\u043a\u043e\u0432\u0430\u0442\u044c \u041a\u0440\u044b\u043c\u0441\u043a\u0438\u0439 \u043c\u043e\u0441\u0442 \u0433\u043e\u0432\u043e\u0440\u044f\u0442 \u043e \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0441\u0442\u0438 \u0434\u0435\u043d\u0430\u0446\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438 \u0432\u0441\u0435\u0439 \u0423\u043a\u0440\u0430\u0438\u043d\u044b",
      "url": "/politika/15236781"
    },
    {
      "text": "\u0421\u041c\u0418: \u0433\u043b\u0430\u0432\u0430 \u0438\u0440\u0430\u043d\u0441\u043a\u043e\u0433\u043e \u0431\u0430\u043d\u043a\u0430 \u043f\u043e\u0434\u043f\u0438\u0441\u0430\u043b \u043c\u0435\u043c\u043e\u0440\u0430\u043d\u0434\u0443\u043c \u0441 \u0440\u0443\u043a\u043e\u0432\u043e\u0434\u0438\u0442\u0435\u043b\u0435\u043c \u0421\u0431\u0435\u0440\u0431\u0430\u043d\u043a\u0430",
      "url": "/ekonomika/15236553"
    },
    {
      "text": "\u041d\u0430 \u0432\u043e\u0441\u0442\u043e\u043a\u0435 \u0413\u0440\u0435\u0446\u0438\u0438 \u0443\u043f\u0430\u043b \u0441\u0430\u043c\u043e\u043b\u0435\u0442 \u0410\u043d-12",
      "url": "/proisshestviya/15236397"
    },
    {
      "text": "\u0412 \u0421\u0428\u0410 \u0441\u0447\u0438\u0442\u0430\u044e\u0442, \u0447\u0442\u043e \u0431\u043b\u0438\u0436\u043d\u0435\u0432\u043e\u0441\u0442\u043e\u0447\u043d\u044b\u0435 \u0441\u0442\u0440\u0430\u043d\u044b \u0443\u0436\u0435 \u043d\u0435 \u0445\u043e\u0442\u044f\u0442 \u0443\u043a\u0440\u0435\u043f\u043b\u0435\u043d\u0438\u044f \u0441\u0432\u044f\u0437\u0435\u0439 \u0441 \u0420\u0424 \u0438 \u041a\u041d\u0420",
