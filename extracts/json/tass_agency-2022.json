  "tass_agency-2022": [
    {
      "text": "\u041f\u043e\u043b\u0438\u0442\u0438\u043a\u0435 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u041f\u0435\u0440\u0441\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u0445 \u0434\u0430\u043d\u043d\u044b\u0445",
      "url": "https://tass.ru/politika-obrabotki-personalnyh-dannyh"
    },
    {
      "text": "",
      "url": "/"
    },
    {
      "text": "\u0428\u043e\u043b\u044c\u0446 \u0437\u0430\u044f\u0432\u0438\u043b, \u0447\u0442\u043e \u0415\u0421 \u043d\u0435 \u0441\u043d\u0438\u043c\u0435\u0442 \u0441\u0430\u043d\u043a\u0446\u0438\u0438 \u0441 \u0420\u0424 \u0432 \u0441\u043b\u0443\u0447\u0430\u0435 \u043c\u0438\u0440\u0430 \u043d\u0430 \u0423\u043a\u0440\u0430\u0438\u043d\u0435 \u043d\u0430 \u0443\u0441\u043b\u043e\u0432\u0438\u044f\u0445 \u041c\u043e\u0441\u043a\u0432\u044b",
      "url": "/mezhdunarodnaya-panorama/15240189"
    },
    {
      "text": "\"\u042a\": \u0442\u0443\u0440\u0431\u0438\u043d\u0443 Siemens \u0434\u043b\u044f \"\u0421\u0435\u0432\u0435\u0440\u043d\u043e\u0433\u043e \u043f\u043e\u0442\u043e\u043a\u0430\" \u043e\u0442\u043f\u0440\u0430\u0432\u0438\u043b\u0438 \u0438\u0437 \u041a\u0430\u043d\u0430\u0434\u044b \u0432 \u0413\u0435\u0440\u043c\u0430\u043d\u0438\u044e",
      "url": "/ekonomika/15240389"
    },
    {
      "text": "\u041c\u0418\u0414 \u041a\u0438\u0442\u0430\u044f \u0437\u0430\u044f\u0432\u0438\u043b, \u0447\u0442\u043e \u043d\u0435 \u0431\u0443\u0434\u0435\u0442 \u0431\u0435\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u044d\u0441\u043a\u0430\u043b\u0430\u0446\u0438\u0438 \u043a\u043e\u043d\u0444\u043b\u0438\u043a\u0442\u0430 \u043d\u0430 \u0423\u043a\u0440\u0430\u0438\u043d\u0435",
      "url": "/mezhdunarodnaya-panorama/15240109"
    },
    {
      "text": "\u041b\u0430\u0432\u0440\u043e\u0432: \u0438\u043d\u0441\u0442\u0440\u0443\u043a\u0442\u043e\u0440\u044b \u041d\u0410\u0422\u041e \u0440\u0443\u043a\u043e\u0432\u043e\u0434\u044f\u0442 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f\u043c\u0438 \u0412\u0421\u0423 \u0438 \u043d\u0430\u0446\u0431\u0430\u0442\u043e\u0432 \u043d\u0430 \u0437\u0435\u043c\u043b\u0435",
      "url": "/politika/15239831"
    },
    {
      "text": "\u0417\u0430\u0445\u0430\u0440\u043e\u0432\u0430 \u043f\u0440\u043e\u043a\u043e\u043c\u043c\u0435\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u043b\u0430 \u0443\u0432\u043e\u043b\u044c\u043d\u0435\u043d\u0438\u0435 \u0417\u0435\u043b\u0435\u043d\u0441\u043a\u0438\u043c \u0433\u0435\u043d\u043f\u0440\u043e\u043a\u0443\u0440\u043e\u0440\u0430 \u0438 \u0433\u043b\u0430\u0432\u044b \u0421\u0411\u0423",
      "url": "/politika/15240071"
    },
    {
      "text": "\u0411\u0438-\u0431\u0438-\u0441\u0438 \u0441\u043e\u043e\u0431\u0449\u0438\u043b\u0430, \u0447\u0442\u043e \u0435\u0449\u0435 \u043e\u0434\u0438\u043d \u0431\u0440\u0438\u0442\u0430\u043d\u0435\u0446 \u043f\u043e\u043f\u0430\u043b \u0432 \u043f\u043b\u0435\u043d \u0432 \u0414\u041d\u0420",
      "url": "/mezhdunarodnaya-panorama/15240009"
    },
    {
      "text": "\u0412\u043e\u0435\u043d\u043d\u0430\u044f \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u044f \u043d\u0430 \u0423\u043a\u0440\u0430\u0438\u043d\u0435",
      "url": "/voennaya-operaciya-na-ukraine"
    },
    {
      "text": "\u0412\u0447\u0435\u0440\u0430, 21:00\u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u043e\u041e\u043d\u043b\u0430\u0439\u043d\u0412\u043e\u0435\u043d\u043d\u0430\u044f \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u044f \u043d\u0430 \u0423\u043a\u0440\u0430\u0438\u043d\u0435. \u041e\u043d\u043b\u0430\u0439\u043d",
      "url": "/armiya-i-opk/15238849"
